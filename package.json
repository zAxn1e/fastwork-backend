{
  "name": "fastwork-project",
  "version": "1.0.0",
  "description": "Internal freelance marketplace API (mini Fastwork-like project)",
  "main": "server.js",
  "_moduleAliases": {
    "@": "src"
  },
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "docs:frontend:install": "npm --prefix frontend-docs install",
    "docs:frontend:build": "npm --prefix frontend-docs run build",
    "dev:with-frontend-docs": "npm run docs:frontend:build && npm run dev",
    "start:with-frontend-docs": "npm run docs:frontend:build && npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:seed": "node prisma/seed.js"
  },
  "keywords": [],
  "author": "Tharathon Kanna",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.3.4",
    "multer": "^2.0.2",
    "pg": "^8.20.0",
    "prisma": "^6.19.0",
    "sharp": "^0.34.4",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
