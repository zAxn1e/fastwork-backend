# Application
POSTGRES_PORT=5432
PORT=3000
OPENAPI_SERVER_URL=http://localhost:3000

# Database (Prisma + PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fastwork_mini?schema=public"

# Internal API Key Security
INTERNAL_API_KEY=change-this
API_KEY_REQUIRED=true

# JWT Authentication
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRES_IN=7d

# Local Media Storage
MEDIA_BASE_DIR=media
MAX_UPLOAD_FILE_SIZE_MB=5

# Media Processing
WEBP_QUALITY=95
THUMBNAIL_WIDTH=320

# Frontend Docs (Docusaurus) served by backend
FRONTEND_DOCS_ENABLED=true
FRONTEND_DOCS_PATH=/frontend-guide
FRONTEND_DOCS_DIST_DIR=frontend-docs/build
